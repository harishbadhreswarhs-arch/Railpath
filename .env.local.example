# Copy to .env.local (do NOT commit secrets).
# Option A: Paste your service account JSON string (escaped) into FIREBASE_SERVICE_ACCOUNT_JSON
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Option B: Or point to a local JSON file (recommended):
FIREBASE_SERVICE_ACCOUNT_PATH="./serviceAccount.json"

# Firebase project id
NEXT_PUBLIC_FIREBASE_PROJECT_ID="railpath-4d7bd"
